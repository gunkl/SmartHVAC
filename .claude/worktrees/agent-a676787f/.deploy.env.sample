# Climate Advisor Deployment Configuration
# Copy this file to .deploy.env and update with your values.
# .deploy.env is git-ignored and will NOT be committed.

# Home Assistant hostname or IP address
HA_HOST=homeassistant.local

# SSH port (default: 22, some setups use 22222)
HA_SSH_PORT=22

# SSH username (common values: hassio, root)
HA_SSH_USER=hassio

# Path to SSH private key (optional — omit to use your default SSH key)
# HA_SSH_KEY=~/.ssh/ha_key

# HA config directory path on the server
HA_CONFIG_PATH=/config
